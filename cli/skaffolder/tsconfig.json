{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es6",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@utilities/*":["src/utilities/*" ],
      "@build/*":["src/build/*" ],
      "@create/*":["src/init/*" ],
      "@start/*":["src/start/*" ],
    }
  },
  "lib": ["es2015"],
  
}
